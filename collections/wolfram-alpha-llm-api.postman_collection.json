      },
      "item": [
        {
          "id": "aceb0327-4cf9-4a46-84a5-837b54f0895d",
          "name": "Wolfram|Alpha Query the LLM API",
          "request": {
            "name": "Wolfram|Alpha Query the LLM API",
            "description": {
              "content": "Submit a natural language query to the Wolfram|Alpha LLM API. Returns structured text with query interpretation, computed results, relevant data, and a link to the full Wolfram|Alpha results page. Optimized for consumption by large language models and AI chat applications.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "llm-api"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) The Wolfram|Alpha AppID used for authentication. Obtain from the Wolfram|Alpha Developer Portal."
                },
                {
                  "disabled": false,
                  "key": "input",
                  "value": "<string>",
                  "description": "(Required) URL-encoded natural language query string."
                },
                {
                  "disabled": false,
                  "key": "maxchars",
                  "value": "<integer>",
                  "description": "Maximum number of characters in the response. Default is 6800."
                },
                {
                  "disabled": false,
                  "key": "assumption",
                  "value": "<string>",
                  "description": "Assumption values to refine query interpretation."
                },
                {
                  "disabled": false,
                  "key": "assumption",
                  "value": "<string>",
                  "description": "Assumption values to refine query interpretation."
                },
                {
                  "disabled": false,
                  "key": "ip",
                  "value": "<string>",
                  "description": "IP address of the query origin for location-aware results."
                },
                {
                  "disabled": false,
                  "key": "latlong",
                  "value": "<string>",
                  "description": "Latitude and longitude for location-based queries (e.g., 40.71,-74.00)."
                },
                {
                  "disabled": false,
                  "key": "timezone",
                  "value": "<string>",
                  "description": "IANA timezone name for the query context."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>",
                  "description": "Measurement system preference. Values are metric or imperial."
                },
                {
                  "disabled": false,
                  "key": "currency",
                  "value": "<string>",
                  "description": "ISO 4217 currency code for financial queries."
                },
                {
                  "disabled": false,
                  "key": "languagecode",
                  "value": "<string>",
                  "description": "BCP 47 language code for query input and response."
                },
                {
                  "disabled": false,
                  "key": "formattimeout",
                  "value": "<integer>",
                  "description": "Maximum processing time in seconds before timeout."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
