{
  "item": [
    {
      "id": "ba13c0d9-dac8-4519-9ac3-cf00047f22a5",
      "name": "Queries",
      "description": {
        "content": "Submit natural language queries for full computational results",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "acf9f5c1-c725-4756-b8ae-5b1b95d0a0fd",
          "name": "Wolfram|Alpha Submit a Full Results Query",
          "request": {
            "name": "Wolfram|Alpha Submit a Full Results Query",
            "description": {
              "content": "Submit a free-form natural language query to the Wolfram|Alpha Full Results API. Returns results in XML (default) or JSON with complete pod data, disambiguations, drilldowns, assumptions, and formatted mathematical/scientific output. Supports asynchronous delivery for long-running computations.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "query"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) Wolfram|Alpha AppID for authentication."
                },
                {
                  "disabled": false,
                  "key": "input",
                  "value": "<string>",
                  "description": "(Required) URL-encoded natural language query string."
                },
                {
                  "disabled": false,
                  "key": "output",
                  "value": "<string>",
                  "description": "Response format. Use json for JSON output; default is XML."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "<string>",
                  "description": "Comma-separated list of content formats to include in results: image, plaintext, mathml, minput, moutput, cell, sound, wav."
                },
                {
                  "disabled": false,
                  "key": "includepodid",
                  "value": "<string>",
                  "description": "Include only pods with these IDs (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "excludepodid",
                  "value": "<string>",
                  "description": "Exclude pods with these IDs (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "podtitle",
                  "value": "<string>",
                  "description": "Include only pods whose title matches this pattern."
                },
                {
                  "disabled": false,
                  "key": "podindex",
                  "value": "<string>",
                  "description": "Include only pods at these ordinal positions (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "scanner",
                  "value": "<string>",
                  "description": "Include only pods generated by specific scanners."
                },
                {
                  "disabled": false,
                  "key": "async",
                  "value": "<string>",
                  "description": "Use asynchronous delivery for long-running computations."
                },
                {
                  "disabled": false,
                  "key": "location",
                  "value": "<string>",
                  "description": "Location name for geographically relevant results."
                },
                {
                  "disabled": false,
                  "key": "latlong",
                  "value": "<string>",
                  "description": "Latitude and longitude for location-aware results."
                },
                {
                  "disabled": false,
                  "key": "ip",
                  "value": "<string>",
                  "description": "IP address for location detection."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>",
                  "description": "Measurement system. Values are metric or imperial."
                },
                {
                  "disabled": false,
                  "key": "width",
                  "value": "<integer>",
                  "description": "Width in pixels for image results. Default is 500."
                },
                {
                  "disabled": false,
                  "key": "maxwidth",
                  "value": "<integer>",
                  "description": "Maximum width in pixels for images."
                },
                {
                  "disabled": false,
                  "key": "mag",
                  "value": "<number>",
                  "description": "Magnification factor for images."
                },
                {
                  "disabled": false,
                  "key": "timeout",
                  "value": "<integer>",
                  "description": "Maximum processing time in seconds. Default is 5."
                },
                {
                  "disabled": false,
                  "key": "assumption",
                  "value": "<string>",
                  "description": "Assumption values to refine query interpretation."
                },
                {
                  "disabled": false,
                  "key": "assumption",
                  "value": "<string>",
                  "description": "Assumption values to refine query interpretation."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
