    {
      "id": "fbda604b-b4a4-4b01-b6e2-4aa3a6ea5160",
      "name": "Queries",
      "description": {
        "content": "Submit queries to receive a rendered image of Wolfram|Alpha results",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "c3e42700-0530-4f2d-9859-07e596c491b6",
          "name": "Wolfram|Alpha Get Simple Image Result",
          "request": {
            "name": "Wolfram|Alpha Get Simple Image Result",
            "description": {
              "content": "Submit a natural language query and receive the complete Wolfram|Alpha result rendered as a static image. Customizable background, foreground, font size, and width. Does not support disambiguation, drilldown, or asynchronous delivery.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "simple"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "appid",
                  "value": "<string>",
                  "description": "(Required) Wolfram|Alpha AppID for authentication."
                },
                {
                  "disabled": false,
                  "key": "i",
                  "value": "<string>",
                  "description": "(Required) URL-encoded input query string."
                },
                {
                  "disabled": false,
                  "key": "layout",
                  "value": "<string>",
                  "description": "Content presentation style. Values are divider (default) or labelbar."
                },
                {
                  "disabled": false,
                  "key": "background",
                  "value": "<string>",
                  "description": "Image background color as HTML color name, hex value, or RGB value."
                },
                {
                  "disabled": false,
                  "key": "foreground",
                  "value": "<string>",
                  "description": "Text color. Values are black (default) or white."
                },
                {
                  "disabled": false,
                  "key": "fontsize",
                  "value": "<integer>",
                  "description": "Font size in points for rendered text. Default is 14."
                },
                {
                  "disabled": false,
                  "key": "width",
                  "value": "<integer>",
                  "description": "Image width in pixels. Default is 500."
                },
                {
                  "disabled": false,
                  "key": "units",
                  "value": "<string>",
                  "description": "Measurement system preference. Values are metric or imperial."
                },
                {
                  "disabled": false,
                  "key": "timeout",
                  "value": "<integer>",
                  "description": "Maximum processing time in seconds. Default is 5."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "image/gif"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
